# ============================================================
# DEV MODE - Docker Compose variable substitution
# Loaded by dev.sh via: docker compose --env-file .env.dev
# These vars are interpolated into docker-compose.dev.yml.
# They are NOT automatically passed to service containers —
# services running locally read their own .env.*.dev files.
# ============================================================

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_MANAGEMENT_PORT=15672

# MinIO (S3-compatible object storage)
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin

# Grafana
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=admin
GF_INSTALL_PLUGINS=grafana-piechart-panel
