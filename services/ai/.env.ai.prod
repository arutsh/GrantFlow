ENV=production
DEBUG=False
POSTGRES_USER=${POSTGRES_USER}
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
POSTGRES_DB=${POSTGRES_DB}
POSTGRES_HOST=grandflow-db
POSTGRES_PORT=5432
POSTGRES_DB_NAME=grandflow_ai
AI_DATABASE_URL=${AI_DATABASE_URL}
# BYOK-only — no platform-level fallback key, left blank intentionally.
ANTHROPIC_API_KEY=
# Generate with: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
ENCRYPTION_KEY=${ENCRYPTION_KEY}
OLLAMA_MODEL=llama3.2
BUDGET_SERVICE_URL=http://budget:8000/api/v1
AI_RATE_LIMIT_PER_HOUR=100
REDIS_URL=redis://redis:6379
LOG_LEVEL=INFO
# Must match the users/budget services' JWT_SECRET_KEY exactly — ai validates
# tokens issued by users via shared.security.dependencies.get_validated_user.
JWT_SECRET_KEY=${JWT_SECRET_KEY}
