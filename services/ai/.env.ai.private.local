ENCRYPTION_KEY=
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
AI_RATE_LIMIT_PER_HOUR=100
REDIS_URL=redis://redis:6379
LOG_LEVEL=INFO
