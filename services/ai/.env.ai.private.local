ENV=local
DEBUG=False
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_HOST=grandflow-db
POSTGRES_PORT=5432
POSTGRES_DB_NAME=grandflow_ai
AI_DATABASE_URL=postgresql://postgres:postgres@grandflow-db:5432/grandflow_ai
ANTHROPIC_API_KEY=
