ENV=production
DEBUG=False
POSTGRES_USER=${POSTGRES_USER}
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
POSTGRES_DB=${POSTGRES_DB}
POSTGRES_HOST=grandflow-db
POSTGRES_PORT=5432
POSTGRES_DB_NAME=grantflow_chat
CHAT_DATABASE_URL=${CHAT_DATABASE_URL}
BUDGET_SERVICE_URL=http://budget:8000/api/v1
AI_SERVICE_URL=http://ai:8000/api/v1
# Must match the users service's JWT_SECRET_KEY exactly — tokens are issued by
# users and validated here.
JWT_SECRET_KEY=${JWT_SECRET_KEY}
LOG_LEVEL=INFO
