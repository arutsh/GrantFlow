ENV=production
TZ=UTC

# RabbitMQ broker — Docker service name in prod, composed from the same
# RABBITMQ_USER/RABBITMQ_PASS secrets the broker itself is configured with.
RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASS}@rabbitmq:5672/

# Redis result backend
REDIS_URL=redis://redis:6379/0

# AI database — used by cleanup_sessions task
AI_DATABASE_URL=${AI_DATABASE_URL}
