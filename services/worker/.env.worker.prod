ENV=production
TZ=UTC

# RabbitMQ broker — Docker service name in prod, must match the other services'
# RABBITMQ_URL secret
RABBITMQ_URL=${{ secrets.RABBITMQ_URL }}

# Redis result backend
REDIS_URL=redis://redis:6379/0

# AI database — used by cleanup_sessions task
AI_DATABASE_URL=${{ secrets.AI_DATABASE_URL }}
