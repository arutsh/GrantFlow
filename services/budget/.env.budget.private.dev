ENV=development
DEBUG=True
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
BUDGET_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/grandflow_budget
REDIS_URL=redis://localhost:6379/0
USER_ALL_SERVICES_URL=http://localhost:8000/api/
CUSTOMER_SERVICE_URL=${USER_ALL_SERVICES_URL}customers/
USER_SERVICE_URL=${USER_ALL_SERVICES_URL}users/
RULE_BASED_MAPPING_ENABLED=False
USE_SEMANTIC_EMBEDDINGS=True
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_EXCHANGE=grandflow.events
RABBITMQ_QUEUE=user_events.budget_service
LOG_LEVEL=INFO